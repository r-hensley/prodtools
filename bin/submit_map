#!/bin/bash

# submit_map - Submit Mu2e grid jobs from a POMS-map JSON via mu2ejobsub
# Wrapper for utils/submit.py

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_SCRIPT="$SCRIPT_DIR/../utils/submit.py"

# Pass help through without environment setup
if [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    exec python3 "$PYTHON_SCRIPT" "$@"
fi

if [[ $# -eq 0 ]]; then
    echo "Usage: submit_map --map <poms_map.json> [--entry N] [--dry-run] [--verbose]"
    echo ""
    echo "For complete help: submit_map --help"
    exit 1
fi

# Set up Mu2e environment (needed for mu2ejobsub, mdh, httokendecode)
source /cvmfs/mu2e.opensciencegrid.org/setupmu2e-art.sh
muse setup ops

exec python3 "$PYTHON_SCRIPT" "$@"
